#!/bin/bash

if [ -z "$ASK_API_URL" ]
then
	echo "Environment variable 'ASK_API_URL' is not set" >&2
	exit 1
fi

if [ -z "$ASK_MODEL" ]
then
	echo "Environment variable 'ASK_MODEL' is not set" >&2
	exit 1
fi

if [ -z "$ASK_API_KEY" ]
then
	echo "Environment variable 'ASK_API_KEY' is not set" >&2
	exit 1
fi


pipe_input=""

if [ ! -t 0 ]
then
	pipe_input=$(cat)
fi

command_arguments=$*

content="$command_arguments$pipe_input"

if [[ -z "$content" ]]; then
    echo "Error. No prompt provided" >&2
    exit 1
fi

json=$(jq -n 	--arg content "$content" \
	'{model:"'"$ASK_MODEL"'", 
		messages: [
	        	{role: "system", content: "You are a CLI tool. Output plain text only. No yapping. Keep the output concise."},
            		{role: "user", content: $content}
        	]
	}'
)

response=$(curl "$ASK_API_URL" -s \
 -H "Content-Type: application/json" \
 -H "Authorization: Bearer $ASK_API_KEY" \
 -d "$json" 
)

if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
    error_msg=$(echo "$response" | jq -r '.error.message // .error')
    echo "API Error: $error_msg" >&2
    exit 1
fi

echo "$response" | jq -r '.choices[0].message.content'




